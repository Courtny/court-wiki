{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*", "./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
