# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://courtwiki:courtwiki_secret@localhost:5432/courtwiki"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-with-openssl-rand-base64-32"

# ─── Search ───────────────────────────────────────────────────────────────────
# Options: "typesense" | "postgres" (default: postgres)
SEARCH_PROVIDER="postgres"
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8108"
TYPESENSE_API_KEY="typesense_dev_key"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: "local" | "s3"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_ROOT="./uploads"
STORAGE_LOCAL_BASE_URL="http://localhost:3000/uploads"

# S3-compatible (Minio, AWS S3, Cloudflare R2, etc.)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""   # for Minio/R2: e.g. http://localhost:9000
# S3_BASE_URL=""   # public CDN URL (optional)

# ─── OAuth Providers (enable only the ones you need) ──────────────────────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# GITLAB_CLIENT_ID=""
# GITLAB_CLIENT_SECRET=""

# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""

# SLACK_CLIENT_ID=""
# SLACK_CLIENT_SECRET=""

# TWITCH_CLIENT_ID=""
# TWITCH_CLIENT_SECRET=""

# AZURE_AD_CLIENT_ID=""
# AZURE_AD_CLIENT_SECRET=""
# AZURE_AD_TENANT_ID="common"

# AUTH0_CLIENT_ID=""
# AUTH0_CLIENT_SECRET=""
# AUTH0_ISSUER=""   # e.g. https://your-tenant.auth0.com

# OKTA_CLIENT_ID=""
# OKTA_CLIENT_SECRET=""
# OKTA_ISSUER=""    # e.g. https://your-domain.okta.com
